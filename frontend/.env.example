# Next.js / CopilotKit Endpoint Configurations
# URL pointing to the FastAPI backend CopilotKit endpoint
NEXT_PUBLIC_COPILOTKIT_ENDPOINT=http://localhost:8000/api/chat

# Map Integrations
# Optional Google Maps API key. If not provided, the frontend will automatically
# fall back to Leaflet/OpenStreetMap.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
