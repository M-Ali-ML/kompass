# Next.js / CopilotKit Endpoint Configurations
# Same-origin relative path: the browser hits whatever host served the page
# (localhost, a LAN IP like 192.168.x.x, etc.) and Next's `/api/:path*` rewrite
# proxies it to the FastAPI backend server-side. Keep this RELATIVE so the app
# works from other devices (phones, other laptops) on the network. Only set an
# absolute URL if the backend lives on a different, externally reachable origin.
NEXT_PUBLIC_COPILOTKIT_ENDPOINT=/api/copilotkit

# Map Integrations
# Browser-restricted Google Maps key for the interactive trip map (Phase 8).
# In Google Cloud, enable the "Maps JavaScript API" + "Geocoding API", create an
# API key restricted to your domain(s)/localhost, and paste it here. When unset,
# the right-hand map panel shows a friendly placeholder and the rest of the app
# keeps working.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Optional: a Map ID enables Advanced Markers / cloud-based map styling. Defaults
# to Google's DEMO_MAP_ID when unset.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=


# Dev tooling
# Hide the Next.js dev tools overlay (route/bundler panel + floating logo
# button). Note: this also suppresses the in-dev error overlay. Remove this
# line to bring the dev tools back.
NEXT_PRIVATE_DISABLE_DEV_OVERLAY_UX=1

