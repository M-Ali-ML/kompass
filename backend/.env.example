# PydanticAI LLM Model Provider Keys
# PydanticAI uses GEMINI_API_KEY for 'gemini-1.5-flash'
GEMINI_API_KEY=your_gemini_api_key_here

# Alternatively, if you switch to OpenAI models in backend/app/agent/agent.py
OPENAI_API_KEY=your_openai_api_key_here

# Telemetry and Observability (Optional)
# If using Langfuse for PydanticAI agent execution telemetry
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# Backend server configuration
PORT=8000
HOST=127.0.0.1
