# PydanticAI LLM Model Provider Keys
# PydanticAI uses GOOGLE_API_KEY for Gemini models
GOOGLE_API_KEY=your_google_api_key_here

# LLM Model Configuration
LLM_MODEL=google:gemini-2.5-flash

# Model for the grounded web-research sub-agent (research_agent.py). Quick,
# parallel, plain-text grounded lookups — a cheap/fast tier is a good fit.
RESEARCH_MODEL=google:gemini-2.5-flash

# Trip "vibe" background image generation (Optional, billed to Google/Gemini credits).
# IMAGE_MODEL paints the destination image; IMAGE_SCENE_MODEL turns the
# conversation into a scene prompt. Defaults are used when unset.
# Set BACKGROUND_IMAGE_ENABLED=false to disable the feature entirely.
IMAGE_MODEL=gemini-2.5-flash-image
IMAGE_SCENE_MODEL=google:gemini-2.5-flash-lite
BACKGROUND_IMAGE_ENABLED=true

# Flights: official Kiwi.com MCP (remote, no API key). Override only to point at
# a different host/proxy. Cheapest-dates fires KIWI_DATE_SAMPLES flex-window
# searches concurrently; each single-date search is capped at KIWI_FLIGHTS_TOP_N.
# KIWI_MCP_URL=https://mcp.kiwi.com/mcp
# KIWI_DATE_SAMPLES=5
# KIWI_FLIGHTS_TOP_N=5

# Accommodations data provider (SerpApi Google Hotels). Optional.
# Get a key at https://serpapi.com/ (free tier: 250 searches/mo).
# When unset, the accommodation tool falls back to the grounded search_web tool.
SERPAPI_API_KEY=your_serpapi_api_key_here

# Accommodations MCP mode: "mock" = deterministic fake data, NO network/cost
# (dev default); "live" = real SerpApi calls (costs money). Flights always use
# the live Kiwi MCP and ignore this flag.
MCP_MODE=mock
# Optional: log every MCP tool call (request + response) as JSON lines.
MCP_LOG_FILE=logs/mcp_calls.jsonl

# Telemetry and Observability (Optional)
# If using Langfuse for PydanticAI agent execution telemetry
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
# Region host: EU https://cloud.langfuse.com | US https://us.cloud.langfuse.com | self-hosted URL
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Backend server configuration
PORT=8000
HOST=127.0.0.1

# Application log level: DEBUG | INFO | WARNING | ERROR (default INFO).
# At DEBUG the app logs a redacted dump of its settings at startup.
LOG_LEVEL=INFO
